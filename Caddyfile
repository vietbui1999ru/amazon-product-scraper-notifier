# Price Drop Monitor — Caddy reverse proxy (CT 200, 10.20.0.2)
# TLS: "tls internal" = Caddy's built-in local CA (no Let's Encrypt needed for .bui TLD)
# Trust the root at: /data/caddy/pki/authorities/local/root.crt
#
# Proxy targets are CT 201 (10.20.0.3) on vmbr1:
#   frontend nginx  → 10.20.0.3:8080
#   backend FastAPI → 10.20.0.3:8000

amazonscraper.viet.bui {
	tls internal

	handle /api/* {
		reverse_proxy 10.20.0.3:8000
	}

	handle {
		reverse_proxy 10.20.0.3:8080
	}
}
