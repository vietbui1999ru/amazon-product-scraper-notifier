# Price Drop Monitor — Caddy (internal HTTP router)
#
# TLS is terminated by Cloudflare Tunnel at the edge.
# Caddy listens on :80 inside Docker — never exposed to the host directly.
# Security headers set here pass through the tunnel to the browser.

:80 {
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}

	handle /docs* {
		reverse_proxy docs:80
	}

	handle /api/* {
		reverse_proxy backend:8000
	}

	handle {
		reverse_proxy frontend:80
	}
}
