# Local dev (docker-compose exposes postgres on 5433, not 5432)
DATABASE_URL=postgresql+asyncpg://pricechecker:pricechecker@localhost:5433/pricechecker
SLACK_WEBHOOK_URL=
LOG_LEVEL=INFO

# Auth — set both to the same random secret for production.
# Generate: openssl rand -hex 32
# Leave blank to disable auth (local dev / Caddy IP-allowlist only).
API_KEY=
VITE_API_KEY=

# Optional — comma-separated origins (default: localhost:3000,localhost:5173)
CORS_ORIGINS=

# Postgres password for prod compose
POSTGRES_PASSWORD=
